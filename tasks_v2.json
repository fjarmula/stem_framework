{
  "benchmark_version": "2.0",
  "name": "Stem Cell Speciation Benchmark",
  "baseline_expectation": {
    "stem_agent_expected_pass_rate": 0.0,
    "reason": "The unmutated genome has no file access organ, no state ledger, no sandbox execution policy, no graph traversal skill, and no persistent multi-turn trace format. A correct answer requires verified artifact-grounded state across turns, not a plausible one-shot response."
  },
  "episode_contract": {
    "episode_is_stateful": true,
    "minimum_turns": 5,
    "agent_visible_artifacts": "Only files listed under public_artifacts may be exposed to the agent.",
    "verifier_only_artifacts": "Files under private_verifier_artifacts are for the future sensor/verifier process only.",
    "success_requires": [
      "exact final answer matching verifier state",
      "complete intermediate action trace",
      "evidence grounded in public artifacts",
      "no reliance on unstated model memory or semantic guessing"
    ]
  },
  "domains": [
    {
      "domain_id": "trading_floor",
      "description": "Stateful trading simulation over CSV market logs and exchange rules. The agent must parse rules, track fills, enforce fees/cooldowns, and emit a complete ledger.",
      "required_capabilities": [
        "read_files",
        "parse_csv",
        "maintain_ledger",
        "validate_exchange_rules"
      ],
      "failure_tags": [
        "csv_parsing_failure",
        "rule_extraction_failure",
        "state_tracking_failure",
        "invalid_trade_action",
        "ledger_mismatch",
        "multi_turn_collapse"
      ],
      "episodes": [
        {
          "episode_id": "trade_001",
          "split": "train",
          "initial_prompt": "Operate inside the simulated trading floor. Use the market log, exchange rules, and starting portfolio to produce the required final portfolio and a full transaction ledger.",
          "public_artifacts": {
            "market_log": "benchmarks/trading/trade_001/market.csv",
            "rules": "benchmarks/trading/trade_001/rules.txt",
            "starting_portfolio": "benchmarks/trading/trade_001/portfolio.json"
          },
          "artifact_manifest": {
            "turns": [
              {
                "turn": 1,
                "observation_delta": {"kind": "rules_and_starting_portfolio"},
                "loads": [
                  {"loader": "path", "artifact": "rules", "as": "rules_path"},
                  {"loader": "text", "artifact": "rules", "as": "rules_text"},
                  {"loader": "path", "artifact": "starting_portfolio", "as": "starting_portfolio_path"},
                  {"loader": "json", "artifact": "starting_portfolio", "as": "starting_portfolio_json"}
                ]
              },
              {
                "turn_range": {"start": 2, "end": "before_final"},
                "observation_delta": {"kind": "market_window"},
                "loads": [
                  {
                    "loader": "csv_window",
                    "artifact": "market_log",
                    "path_as": "market_log_path",
                    "row_start_as": "row_start",
                    "rows_as": "rows"
                  }
                ]
              },
              {
                "turn": 5,
                "observation_delta": {"kind": "finalization_window"},
                "loads": [
                  {"loader": "path", "artifact": "market_log", "as": "market_log_path"}
                ]
              }
            ]
          },
          "output_contract": {
            "final_artifact": {
              "required_keys": ["final_portfolio", "ledger"],
              "final_portfolio_required_keys": ["cash", "positions"]
            }
          },
          "clinical_probes": [
            {
              "name": "final_portfolio_present",
              "source": "final_artifact.final_portfolio",
              "assert": "exists",
              "failure_tags": ["clinical_probe_failure", "incomplete_final_artifact"],
              "critique": "The final artifact must expose a final_portfolio object before the ledger verifier can reason about state."
            },
            {
              "name": "ledger_progress_present",
              "source": "final_artifact.ledger",
              "assert": "non_empty",
              "failure_tags": ["clinical_probe_failure", "ledger_mismatch"],
              "critique": "The final artifact must include a non-empty ledger derived from observed state transitions."
            }
          ],
          "private_verifier_artifacts": {
            "expected": "benchmarks/private/trading/trade_001/expected.json"
          },
          "turns": [
            {"turn": 1, "event": "load_rules_and_starting_portfolio"},
            {"turn": 2, "event": "parse_market_window"},
            {"turn": 3, "event": "submit_trade_batch"},
            {"turn": 4, "event": "apply_fills_fees_and_cooldowns"},
            {"turn": 5, "event": "submit_final_ledger"}
          ]
        },
        {
          "episode_id": "trade_002",
          "split": "validation",
          "initial_prompt": "Operate inside the simulated trading floor. Build the requested close portfolio using only legal trades from the CSV tape.",
          "public_artifacts": {
            "market_log": "benchmarks/trading/trade_002/market.csv",
            "rules": "benchmarks/trading/trade_002/rules.txt",
            "starting_portfolio": "benchmarks/trading/trade_002/portfolio.json"
          },
          "artifact_manifest": {
            "turns": [
              {
                "turn": 1,
                "observation_delta": {"kind": "rules_and_starting_portfolio"},
                "loads": [
                  {"loader": "path", "artifact": "rules", "as": "rules_path"},
                  {"loader": "text", "artifact": "rules", "as": "rules_text"},
                  {"loader": "path", "artifact": "starting_portfolio", "as": "starting_portfolio_path"},
                  {"loader": "json", "artifact": "starting_portfolio", "as": "starting_portfolio_json"}
                ]
              },
              {
                "turn_range": {"start": 2, "end": "before_final"},
                "observation_delta": {"kind": "market_window"},
                "loads": [
                  {
                    "loader": "csv_window",
                    "artifact": "market_log",
                    "path_as": "market_log_path",
                    "row_start_as": "row_start",
                    "rows_as": "rows"
                  }
                ]
              },
              {
                "turn": 5,
                "observation_delta": {"kind": "finalization_window"},
                "loads": [
                  {"loader": "path", "artifact": "market_log", "as": "market_log_path"}
                ]
              }
            ]
          },
          "output_contract": {
            "final_artifact": {
              "required_keys": ["final_portfolio", "ledger"],
              "final_portfolio_required_keys": ["cash", "positions"]
            }
          },
          "clinical_probes": [
            {
              "name": "final_portfolio_present",
              "source": "final_artifact.final_portfolio",
              "assert": "exists",
              "failure_tags": ["clinical_probe_failure", "incomplete_final_artifact"],
              "critique": "The final artifact must expose a final_portfolio object before the ledger verifier can reason about state."
            },
            {
              "name": "ledger_progress_present",
              "source": "final_artifact.ledger",
              "assert": "non_empty",
              "failure_tags": ["clinical_probe_failure", "ledger_mismatch"],
              "critique": "The final artifact must include a non-empty ledger derived from observed state transitions."
            }
          ],
          "private_verifier_artifacts": {
            "expected": "benchmarks/private/trading/trade_002/expected.json"
          },
          "turns": [
            {"turn": 1, "event": "load_rules_and_starting_portfolio"},
            {"turn": 2, "event": "parse_market_window"},
            {"turn": 3, "event": "submit_trade_batch"},
            {"turn": 4, "event": "apply_fills_fees_and_cooldowns"},
            {"turn": 5, "event": "submit_final_ledger"}
          ]
        }
      ]
    },
    {
      "domain_id": "security_sandbox",
      "description": "Safe local toy security sandbox. The agent must inspect isolated source fixtures, isolate the correct vector from distractors, run or describe a probe, and submit a minimal reproducer accepted by the verifier.",
      "required_capabilities": [
        "read_directory_tree",
        "inspect_source",
        "isolate_candidate_vector",
        "run_local_verifier"
      ],
      "failure_tags": [
        "directory_traversal_failure",
        "vector_isolation_failure",
        "compile_failure",
        "sandbox_violation",
        "missing_execution_trace",
        "multi_turn_collapse"
      ],
      "episodes": [
        {
          "episode_id": "sec_001",
          "split": "train",
          "initial_prompt": "Analyze the isolated toy document service. Find the one candidate input that triggers the intended sandbox-only bug and submit a minimal proof object.",
          "public_artifacts": {
            "source_dir": "benchmarks/security/sec_001/app",
            "candidate_vectors": "benchmarks/security/sec_001/candidates/vectors.txt"
          },
          "artifact_manifest": {
            "turns": [
              {
                "turn": 1,
                "observation_delta": {"kind": "directory_leaf"},
                "loads": [
                  {
                    "loader": "directory_listing",
                    "artifact": "source_dir",
                    "glob": "*.py",
                    "root_as": "source_dir",
                    "first_path_as": "leaf",
                    "names_as": "all_visible_leaf_names"
                  }
                ]
              },
              {
                "turn": 2,
                "observation_delta": {"kind": "source_file"},
                "loads": [
                  {
                    "loader": "file_glob_text",
                    "artifact": "source_dir",
                    "glob": "*.py",
                    "index": 0,
                    "path_as": "path",
                    "content_as": "content"
                  }
                ]
              },
              {
                "turn_range": {"start": 3, "end": "before_final"},
                "observation_delta": {"kind": "candidate_vector_window"},
                "loads": [
                  {
                    "loader": "lines_window",
                    "artifact": "candidate_vectors",
                    "path_as": "candidate_vectors_path",
                    "line_start_as": "line_start",
                    "values_as": "values"
                  }
                ]
              },
              {
                "turn": 4,
                "observation_delta": {
                  "kind": "public_behavior_probe",
                  "selection_goal": "Select the probe row marked selection_match=true; copy that row's input key and observed_result exactly."
                },
                "loads": [
                  {
                    "loader": "python_function_probe",
                    "source_artifact": "source_dir",
                    "glob": "*.py",
                    "index": 0,
                    "function": "fetch_document",
                    "inputs_artifact": "candidate_vectors",
                    "results_as": "probe_results",
                    "input_label": "vector",
                    "input_key_as": "probe_input_key",
                    "result_key_as": "probe_result_key",
                    "selection_key_as": "probe_selection_key",
                    "select_when": {
                      "result_matches_any": ["^sandbox-token"]
                    },
                    "source_path_as": "probe_source_path",
                    "inputs_path_as": "probe_inputs_path"
                  }
                ]
              },
              {
                "turn": 5,
                "observation_delta": {"kind": "finalization_window"},
                "loads": [
                  {"loader": "path", "artifact": "source_dir", "as": "source_dir"},
                  {"loader": "path", "artifact": "candidate_vectors", "as": "candidate_vectors_path"}
                ]
              }
            ]
          },
          "output_contract": {
            "final_artifact": {
              "required_keys": ["proof_object"],
              "proof_object_required_keys": ["observed_result", "vector"]
            }
          },
          "clinical_probes": [
            {
              "name": "proof_object_schema",
              "source": "final_artifact.proof_object",
              "assert": "contains_keys",
              "keys": ["observed_result", "vector"],
              "failure_tags": ["clinical_probe_failure", "vector_isolation_failure", "incomplete_final_artifact"],
              "critique": "The proof_object must use the output_contract key names for this episode."
            },
            {
              "name": "proof_artifact_present",
              "source": "final_artifact",
              "assert": "non_empty",
              "failure_tags": ["clinical_probe_failure", "vector_isolation_failure"],
              "critique": "The final artifact must contain a non-empty proof object grounded in the observed source and candidate inputs."
            }
          ],
          "private_verifier_artifacts": {
            "expected": "benchmarks/private/security/sec_001/expected.json",
            "verifier": "benchmarks/private/security/sec_001/verify.py"
          },
          "turns": [
            {"turn": 1, "event": "enumerate_directory_tree"},
            {"turn": 2, "event": "inspect_source_and_rules"},
            {"turn": 3, "event": "isolate_candidate_vector"},
            {"turn": 4, "event": "run_probe_against_local_sandbox"},
            {"turn": 5, "event": "submit_minimal_reproduction"}
          ]
        },
        {
          "episode_id": "sec_002",
          "split": "validation",
          "initial_prompt": "Analyze the isolated toy packet parser. Identify the candidate packet that reaches the protected branch and submit a minimal proof object.",
          "public_artifacts": {
            "source_dir": "benchmarks/security/sec_002/app",
            "candidate_vectors": "benchmarks/security/sec_002/candidates/vectors.txt"
          },
          "artifact_manifest": {
            "turns": [
              {
                "turn": 1,
                "observation_delta": {"kind": "directory_leaf"},
                "loads": [
                  {
                    "loader": "directory_listing",
                    "artifact": "source_dir",
                    "glob": "*.py",
                    "root_as": "source_dir",
                    "first_path_as": "leaf",
                    "names_as": "all_visible_leaf_names"
                  }
                ]
              },
              {
                "turn": 2,
                "observation_delta": {"kind": "source_file"},
                "loads": [
                  {
                    "loader": "file_glob_text",
                    "artifact": "source_dir",
                    "glob": "*.py",
                    "index": 0,
                    "path_as": "path",
                    "content_as": "content"
                  }
                ]
              },
              {
                "turn_range": {"start": 3, "end": "before_final"},
                "observation_delta": {"kind": "candidate_vector_window"},
                "loads": [
                  {
                    "loader": "lines_window",
                    "artifact": "candidate_vectors",
                    "path_as": "candidate_vectors_path",
                    "line_start_as": "line_start",
                    "values_as": "values"
                  }
                ]
              },
              {
                "turn": 4,
                "observation_delta": {
                  "kind": "public_behavior_probe",
                  "selection_goal": "Select the probe row marked selection_match=true; copy that row's input key and observed_result exactly."
                },
                "loads": [
                  {
                    "loader": "python_function_probe",
                    "source_artifact": "source_dir",
                    "glob": "*.py",
                    "index": 0,
                    "function": "authorize",
                    "inputs_artifact": "candidate_vectors",
                    "results_as": "probe_results",
                    "input_label": "packet",
                    "input_key_as": "probe_input_key",
                    "result_key_as": "probe_result_key",
                    "selection_key_as": "probe_selection_key",
                    "select_when": {
                      "result_matches_any": ["^GRANTED:"]
                    },
                    "source_path_as": "probe_source_path",
                    "inputs_path_as": "probe_inputs_path"
                  }
                ]
              },
              {
                "turn": 5,
                "observation_delta": {"kind": "finalization_window"},
                "loads": [
                  {"loader": "path", "artifact": "source_dir", "as": "source_dir"},
                  {"loader": "path", "artifact": "candidate_vectors", "as": "candidate_vectors_path"}
                ]
              }
            ]
          },
          "output_contract": {
            "final_artifact": {
              "required_keys": ["proof_object"],
              "proof_object_required_keys": ["observed_result", "packet"]
            }
          },
          "clinical_probes": [
            {
              "name": "proof_object_schema",
              "source": "final_artifact.proof_object",
              "assert": "contains_keys",
              "keys": ["observed_result", "packet"],
              "failure_tags": ["clinical_probe_failure", "vector_isolation_failure", "incomplete_final_artifact"],
              "critique": "The proof_object must use the output_contract key names for this episode."
            },
            {
              "name": "proof_artifact_present",
              "source": "final_artifact",
              "assert": "non_empty",
              "failure_tags": ["clinical_probe_failure", "vector_isolation_failure"],
              "critique": "The final artifact must contain a non-empty proof object grounded in the observed source and candidate inputs."
            }
          ],
          "private_verifier_artifacts": {
            "expected": "benchmarks/private/security/sec_002/expected.json",
            "verifier": "benchmarks/private/security/sec_002/verify.py"
          },
          "turns": [
            {"turn": 1, "event": "enumerate_directory_tree"},
            {"turn": 2, "event": "inspect_source_and_rules"},
            {"turn": 3, "event": "isolate_candidate_vector"},
            {"turn": 4, "event": "run_probe_against_local_sandbox"},
            {"turn": 5, "event": "submit_minimal_reproduction"}
          ]
        }
      ]
    },
    {
      "domain_id": "matrix_database",
      "description": "Abstract matrix database exploration. The agent must load a graph schema, traverse edges, filter relations and properties, and return exact answer sets with path traces.",
      "required_capabilities": [
        "read_json",
        "graph_traversal",
        "relation_filtering",
        "path_trace_emission"
      ],
      "failure_tags": [
        "schema_loading_failure",
        "graph_traversal_failure",
        "relation_filter_failure",
        "path_trace_missing",
        "answer_set_mismatch",
        "multi_turn_collapse"
      ],
      "episodes": [
        {
          "episode_id": "matrix_001",
          "split": "train",
          "initial_prompt": "Explore the matrix database and answer the relational query using only discovered records. Include a path trace for each returned node.",
          "public_artifacts": {
            "nodes": "benchmarks/matrix/matrix_001/nodes.json",
            "edges": "benchmarks/matrix/matrix_001/edges.json",
            "query": "benchmarks/matrix/matrix_001/query.txt"
          },
          "artifact_manifest": {
            "turns": [
              {
                "turn": 1,
                "observation_delta": {"kind": "query"},
                "loads": [
                  {"loader": "path", "artifact": "query", "as": "query_path"},
                  {"loader": "text", "artifact": "query", "as": "query_text"}
                ]
              },
              {
                "turn": 2,
                "observation_delta": {"kind": "nodes"},
                "loads": [
                  {"loader": "path", "artifact": "nodes", "as": "nodes_path"},
                  {"loader": "json", "artifact": "nodes", "as": "nodes"}
                ]
              },
              {
                "turn": 3,
                "observation_delta": {"kind": "edges"},
                "loads": [
                  {"loader": "path", "artifact": "edges", "as": "edges_path"},
                  {"loader": "json", "artifact": "edges", "as": "edges"}
                ]
              },
              {
                "turn_range": {"start": 4, "end": "final"},
                "observation_delta": {"kind": "finalization_window"},
                "loads": [
                  {"loader": "artifact_map", "as": "known_artifacts"}
                ]
              }
            ]
          },
          "output_contract": {
            "final_artifact": {
              "required_keys": ["answer_set", "paths"]
            }
          },
          "clinical_probes": [
            {
              "name": "answer_set_shape",
              "source": "final_artifact.answer_set",
              "assert": "type",
              "expected_type": "array",
              "failure_tags": ["clinical_probe_failure", "answer_set_mismatch"],
              "critique": "The final artifact must expose answer_set as a list of terminal identifiers."
            },
            {
              "name": "path_trace_progress",
              "source": "final_artifact.paths",
              "assert": "non_empty",
              "failure_tags": ["clinical_probe_failure", "graph_traversal_failure", "path_trace_missing"],
              "critique": "The final artifact must include non-empty path traces after query, node, and edge observations have been loaded."
            }
          ],
          "private_verifier_artifacts": {
            "expected": "benchmarks/private/matrix/matrix_001/expected.json"
          },
          "turns": [
            {"turn": 1, "event": "load_schema_and_seed"},
            {"turn": 2, "event": "expand_first_relation"},
            {"turn": 3, "event": "filter_second_relation"},
            {"turn": 4, "event": "resolve_ambiguous_paths"},
            {"turn": 5, "event": "submit_answer_set_with_path_trace"}
          ]
        },
        {
